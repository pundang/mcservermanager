<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MCServerManager.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="MCServerManager.Views.ConsoleView"
             x:DataType="vm:ConsoleViewModel">
    <Design.DataContext>
        <vm:ConsoleViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto" RowSpacing="4">
        <ScrollViewer x:Name="LogScrollList" Grid.Row="0" ScrollChanged="LogScrollList_ScrollChanged">
            <ItemsControl ItemsSource="{Binding ConsoleOutputLines}" />
        </ScrollViewer>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8" HorizontalAlignment="Stretch">
            <TextBox x:Name="CmdBox" Grid.Column="0" KeyDown="CmdBox_KeyDown"/>

            <Button Grid.Column="1" Click="Button_Click">
                <PathIcon Data="{StaticResource play_regular}"/>
            </Button>
        </Grid>
    </Grid>
</UserControl>
