        <StreamGeometry x:Key="stop_regular">M19.25 4.5C19.3881 4.5 19.5 4.61193 19.5 4.75V19.25C19.5 19.3881 19.3881 19.5 19.25 19.5H4.75C4.61193 19.5 4.5 19.3881 4.5 19.25V4.75C4.5 4.61193 4.61193 4.5 4.75 4.5H19.25ZM4.75 3C3.7835 3 3 3.7835 3 4.75V19.25C3 20.2165 3.7835 21 4.75 21H19.25C20.2165 21 21 20.2165 21 19.25V4.75C21 3.7835 20.2165 3 19.25 3H4.75Z</StreamGeometry>
        <StreamGeometry x:Key="arrow_sync_regular">M7.74944331,5.18010908 C8.0006303,5.50946902 7.93725859,5.9800953 7.60789865,6.23128229 C5.81957892,7.59514774 4.75,9.70820889 4.75,12 C4.75,15.7359812 7.57583716,18.8119527 11.2066921,19.2070952 L10.5303301,18.5303301 C10.2374369,18.2374369 10.2374369,17.7625631 10.5303301,17.4696699 C10.7965966,17.2034034 11.2132603,17.1791973 11.5068718,17.3970518 L11.5909903,17.4696699 L13.5909903,19.4696699 C13.8572568,19.7359365 13.8814629,20.1526002 13.6636084,20.4462117 L13.5909903,20.5303301 L11.5909903,22.5303301 C11.298097,22.8232233 10.8232233,22.8232233 10.5303301,22.5303301 C10.2640635,22.2640635 10.2398575,21.8473998 10.4577119,21.5537883 L10.5303301,21.4696699 L11.280567,20.7208479 C6.78460951,20.3549586 3.25,16.5902554 3.25,12 C3.25,9.23526399 4.54178532,6.68321165 6.6982701,5.03856442 C7.02763004,4.78737743 7.49825632,4.85074914 7.74944331,5.18010908 Z M13.4696699,1.46966991 C13.7625631,1.76256313 13.7625631,2.23743687 13.4696699,2.53033009 L12.7204313,3.27923335 C17.2159137,3.64559867 20.75,7.4100843 20.75,12 C20.75,14.6444569 19.5687435,17.0974104 17.5691913,18.7491089 C17.2498402,19.0129038 16.7771069,18.9678666 16.513312,18.6485156 C16.2495171,18.3291645 16.2945543,17.8564312 16.6139054,17.5926363 C18.2720693,16.2229363 19.25,14.1922015 19.25,12 C19.25,8.26436254 16.4246828,5.18861329 12.7943099,4.7930139 L13.4696699,5.46966991 C13.7625631,5.76256313 13.7625631,6.23743687 13.4696699,6.53033009 C13.1767767,6.8232233 12.701903,6.8232233 12.4090097,6.53033009 L10.4090097,4.53033009 C10.1161165,4.23743687 10.1161165,3.76256313 10.4090097,3.46966991 L12.4090097,1.46966991 C12.701903,1.1767767 13.1767767,1.1767767 13.4696699,1.46966991 Z</StreamGeometry>
    </UserControl.Resources>

    <DockPanel Margin="8" HorizontalSpacing="8" LastChildFill="True">
        <!-- Sidebar -->
        <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource SystemRegionColor}">
            <!-- <StackPanel HorizontalAlignment="Left">
            <Button Classes="home-button" HorizontalAlignment="Center" VerticalAlignment="Center">
            <PathIcon Data="{StaticResource home_regular}" Foreground="White" Width="16" Height="16" />
            </Button>
            </StackPanel> -->

            <!-- Tab list -->
            <StackPanel Grid.Row="1" Spacing="4">
                <RadioButton Classes="sidebar-tab" GroupName="Tabs"
                             Content="Players" Command="{Binding SelectTabCommand}" CommandParameter="Players" IsChecked="True" />
                <RadioButton Classes="sidebar-tab" GroupName="Tabs"
                             Content="Console" Command="{Binding SelectTabCommand}" CommandParameter="Console" />
                <RadioButton Classes="sidebar-tab" GroupName="Tabs"
                             Content="Options" Command="{Binding SelectTabCommand}" CommandParameter="Options" />
            </StackPanel>

            <!-- Start | Stop button -->
            <Button Grid.Row="2" Classes="toggle-start-btn" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Command="{Binding ToggleRunningCommand}"
                    Classes.start-btn="{Binding !IsRunning}"
                    Classes.stop-btn="{Binding IsRunning}"
                    IsEnabled="{Binding ToggleButtonEnabled}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <!-- Start | Stop icon -->
                    <!-- <PathIcon Data="{DynamicResource {Binding ToggleButtonIcon}}" Width="12" Height="12" VerticalAlignment="Center" IsVisible="True" /> -->

                    <!-- Status Text -->
                    <TextBlock Text="{Binding ToggleButtonText}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Content area -->
        <ContentControl Content="{Binding CurrentViewModel}" />
    </DockPanel>

    <UserControl.Styles>
        <!-- Home button -->
        <Style Selector="Button.home-button">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- Sidebar buttons -->
        <Style Selector="RadioButton.sidebar-tab">
            <Setter Property="Padding" Value="15,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontWeight" Value="Light" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="PART_Bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="RadioButton.sidebar-tab:pointerover /template/ Border#PART_Bg">
            <Setter Property="Background" Value="{DynamicResource SystemControlTransientBackgroundBrush}" />
        </Style>

        <Style Selector="RadioButton.sidebar-tab:checked /template/ Border#PART_Bg">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAccentBrush}" />
        </Style>

        <Style Selector="RadioButton.sidebar-tab:checked">
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="RadioButton.sidebar-tab:checked">
            <Setter Property="FontWeight" Value="Normal" />
        </Style>

        <!-- Start | Stop button styles -->
        <Style Selector="Button.toggle-start-btn">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="0,10" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!-- Override default pointover event -->
        <Style Selector="Button.toggle-start-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{Binding $parent[Button].Background}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="Button.start-btn">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAccentBrush}" />

            <Style Selector="^:pressed /template/ ContentPresenter">
                <Setter Property="Background" Value="#71a144" />
            </Style>
        </Style>

        <Style Selector="Button.stop-btn">
            <Setter Property="Background" Value="#c55454" />

            <Style Selector="^:pressed /template/ ContentPresenter">
                <Setter Property="Background" Value="#c55d5d" />
            </Style>
        </Style>
    </UserControl.Styles>
</UserControl>
